# Copy this file to .env and fill it in. .env is gitignored — your info stays local.

# How you sign your emails
SENDER_NAME=Your Name
SENDER_PHONE=555-555-5555

# The Gmail account the inquiries send from (replies arrive here too)
GMAIL_USER=you@gmail.com

# NOT your Gmail password. Create an app password:
# Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_APP_PASSWORD=

# Seconds between outgoing emails (keeps a batch from looking like spam)
SEND_INTERVAL_SECONDS=20
